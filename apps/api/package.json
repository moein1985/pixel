{
  "name": "@pixel/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@trpc/server": "^11.0.0",
    "@pixel/db": "workspace:*",
    "@pixel/shared": "workspace:*",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/cookie": "^9.3.0",
    "@fastify/websocket": "^10.0.0",
    "@fastify/multipart": "^8.3.0",
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0",
    "ioredis": "^5.4.0",
    "bullmq": "^5.7.0",
    "zod": "^3.23.0",
    "jsonwebtoken": "^9.0.0",
    "argon2": "^0.40.0",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/crypto-js": "^4.2.0"
  }
